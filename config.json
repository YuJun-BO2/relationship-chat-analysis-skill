{
  "period_start": null,
  "period_end": null,
  "output_folder": "relationship-analysis",
  "require_explicit_file_selection": true,
  "require_write_confirmation": true,
  "default_manifest_detail": "redacted_metadata_only",
  "store_raw_messages_by_default": false,
  "redact_identifiers_by_default": true,
  "default_focus": [
    "communication_patterns",
    "conflict_cycles",
    "repair_attempts",
    "emotional_needs",
    "avoidance_and_distance",
    "boundaries_and_safety",
    "effort_balance",
    "blind_spots"
  ],
  "supported_export_sources": [
    "line",
    "whatsapp",
    "telegram",
    "imessage",
    "messenger",
    "instagram_dm",
    "discord",
    "sms",
    "plain_text",
    "unknown"
  ],
  "message_noise_patterns": [
    "system_message",
    "media_placeholder",
    "sticker",
    "deleted_message",
    "call_log",
    "payment_or_transfer_notice",
    "encryption_notice",
    "join_or_leave_notice",
    "duplicate_export_block",
    "forwarded_irrelevant_content"
  ],
  "episode_gap_hours": 12,
  "conflict_window_hours": 24,
  "minimum_messages_per_episode": 3,
  "min_episodes_for_pattern": 2,
  "max_quote_length_chars": 280,
  "privacy_redaction": true,
  "analysis_model": "sonnet",
  "synthesis_model": "sonnet",
  "max_parallel_agents": 8,
  "batch_size_episodes": 6,
  "safety_flags": [
    "threats",
    "coercion",
    "stalking_or_surveillance",
    "physical_violence",
    "sexual_pressure",
    "self_harm",
    "harassment",
    "isolation_from_support",
    "financial_control"
  ],
  "output_sections": [
    "relationship_timeline",
    "data_quality_and_missing_context",
    "communication_pattern",
    "emotional_needs_and_bids",
    "conflict_escalation_pattern",
    "repair_and_reconnection_pattern",
    "distance_avoidance_and_coldness",
    "boundaries_pressure_and_safety",
    "effort_balance_and_power_dynamics",
    "repeating_loops",
    "blind_spots_for_each_person",
    "what_the_evidence_does_not_support"
  ]
}
